{
  "name": "leather-works",
  "version": "2.0.0",
  "main": "dist-electron/electron/main.cjs",

  "build": {
    "appId": "com.a-bedetse.leather-works",
    "productName": "Leather Works",

    "directories": {
      "output": "dist"
    },

    "files": [
      "dist-electron/**/*",
      "dist-react/**/*",
      "package.json"
    ],

    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],

    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },

    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "icon": "build"
    },

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    }
  }
}