{
  "name": "leather-works",
  "version": "2.0.0",
  "main": "dist-electron/electron/main.cjs",

  "build": {
    "appId": "com.a-bedetse.leather-works",

    "files": [
      "dist-electron/**/*",
      "dist-react/**/*",
      "package.json"
    ],

    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },

    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "icon": "build"
    },

    "win": {
      "target": [
        "portable",
        "msi"
      ],
      "icon": "build/icon.ico"
    }
  }
}