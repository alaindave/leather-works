{
  "compilerOptions": {
    "strict": true,

    "target": "ES2022",
    "module": "CommonJS",

    "outDir": "../../dist-electron",
    "rootDir": "./",

    "moduleResolution": "node",

    "skipLibCheck": true,

    "types": ["node", "electron"],

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["./**/*"]
}