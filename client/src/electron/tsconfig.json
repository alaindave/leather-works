{
  "compilerOptions": {
    "strict": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "target": "ES2022",
    "module": "node16",
    "outDir": "../../dist-electron",
    "rootDir": "../",
    "moduleResolution": "node16",
    "skipLibCheck": true,
    "types": ["node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },

  "include": [
    "./**/*",
    "../shared/**/*",
    "../../**/*.d.ts",
    "../shared/types/global.d.ts"
  ]
}
